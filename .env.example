APP_NAME=Identity Access Service
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://iam:iam@db:5432/iam
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000
JWT_SECRET_KEY=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_ISSUER=identity-access-service
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=10
REGISTER_RATE_LIMIT_REQUESTS=5
REFRESH_RATE_LIMIT_REQUESTS=20
